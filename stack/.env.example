# Copying this file to .env is intentionally not required.
# Use scripts/secrets/set-kv-secret.ps1 and scripts/start-stack.ps1 instead.

KAHLE_ROOT=C:/kahle-vinci

# Pinned runtime images currently referenced by docker-compose.yml.
OPEN_WEBUI_IMAGE=ghcr.io/open-webui/open-webui:v0.6.43
N8N_IMAGE=n8nio/n8n:2.16.1
QDRANT_IMAGE=qdrant/qdrant:v1.17.1
SEARXNG_IMAGE=searxng/searxng:2026.4.13-ee66b070a

# IONOS OpenAI-compatible endpoint and model IDs.
IONOS_OPENAI_BASE_URL=https://openai.inference.de-txl.ionos.com/v1
IONOS_CHAT_MODEL_DEFAULT=mistralai/Mistral-Small-24B-Instruct
IONOS_CHAT_MODEL_REASONING=openai/gpt-oss-120b
IONOS_EMBEDDING_MODEL=BAAI/bge-m3

# Public localhost URL used in generated file download links.
PUBLIC_BASE_URL=http://localhost:8091

# Optional n8n websearch hook.
N8N_SAFE_WEBSEARCH_WEBHOOK_URL=http://n8n:5678/webhook/safe-websearch/h576htdr-5b9t-89r8-61wx-8a50bh988m6a
N8N_SAFE_WEBSEARCH_API_KEY=
N8N_SAFE_WEBSEARCH_TIMEOUT=50

# Required secrets are stored outside the repo in Windows Credential Manager:
# IONOS_API_KEY
# WEBUI_SECRET_KEY
# N8N_BASIC_AUTH_PASSWORD
# N8N_ENCRYPTION_KEY
# SEARXNG_SECRET_KEY
# FILE_LINK_SECRET
# OWUI_FILE_PROXY_API_KEY
# DOC_WORKER_API_KEY
